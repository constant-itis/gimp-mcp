{
  "name": "sticker-outline",
  "description": "Die-cut sticker edge: a thick solid outline hugging the active layer's shape, with a soft drop shadow underneath. Great for logos/graphics on transparent backgrounds.",
  "params": { "outline": 14, "outline_color": "#ffffff", "shadow": 18 },
  "steps": [
    { "scheme": "(gimp-image-select-item $IMG CHANNEL-OP-REPLACE $LAYER)" },
    { "scheme": "(gimp-selection-grow $IMG {outline})" },
    { "bind": "EDGE", "scheme": "(car (gimp-layer-new $IMG $W $H RGBA-IMAGE \"sticker-edge\" 100 LAYER-MODE-NORMAL))" },
    { "scheme": "(gimp-image-insert-layer $IMG $EDGE 0 -1)" },
    { "scheme": "(gimp-image-lower-item $IMG $EDGE)" },
    { "scheme": "(gimp-drawable-fill $EDGE FILL-TRANSPARENT)" },
    { "scheme": "(gimp-context-set-foreground {outline_color})" },
    { "scheme": "(gimp-image-set-active-layer $IMG $EDGE)" },
    { "scheme": "(gimp-edit-fill $EDGE FILL-FOREGROUND)" },
    { "scheme": "(gimp-selection-none $IMG)" },
    { "scheme": "(script-fu-drop-shadow $IMG $EDGE 0 0 {shadow} '(0 0 0) 55 FALSE)" }
  ]
}
