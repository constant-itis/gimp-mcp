[
 {"id":"duotone-ellipse-pop","task":"High-contrast teal-to-magenta duotone over overlapping ellipse shapes.","steps":[
  {"tool":"new_image","args":{"width":800,"height":600},"capture":"IMG"},
  {"tool":"gradient_fill","args":{"image_id":"$IMG","color1":"#303040","color2":"#c0c0d0","direction":"vertical"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"ellipse","x":120,"y":140,"width":360,"height":360}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#e8e4d8"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"ellipse","x":360,"y":220,"width":320,"height":320}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#404050"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"none"}},
  {"tool":"desaturate","args":{"image_id":"$IMG","mode":"luminosity"}},
  {"tool":"curves_adjust","args":{"image_id":"$IMG","channel":"red","points":"0,20 128,90 255,235"}},
  {"tool":"curves_adjust","args":{"image_id":"$IMG","channel":"blue","points":"0,60 128,150 255,210"}},
  {"tool":"brightness_contrast","args":{"image_id":"$IMG","brightness":0,"contrast":40}}]},

 {"id":"grunge-oilify-texture","task":"Gritty grunge treatment via oilify plus emboss over a mottled gradient base.","steps":[
  {"tool":"new_image","args":{"width":768,"height":768},"capture":"IMG"},
  {"tool":"gradient_fill","args":{"image_id":"$IMG","color1":"#6b5a3e","color2":"#2a2622","direction":"diagonal"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"rectangle","x":80,"y":120,"width":300,"height":420}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#8a7550"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"rectangle","x":400,"y":220,"width":280,"height":360}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#3a3430"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"none"}},
  {"tool":"oilify","args":{"image_id":"$IMG","mask_size":9,"intensity":6}},
  {"tool":"emboss","args":{"image_id":"$IMG","azimuth":135,"elevation":30,"depth":3,"bumpmap":true}},
  {"tool":"brightness_contrast","args":{"image_id":"$IMG","brightness":-10,"contrast":30}}]},

 {"id":"embossed-metal-plate","task":"Brushed embossed-metal look with motion-streaked highlights and a dark border.","steps":[
  {"tool":"new_image","args":{"width":800,"height":600},"capture":"IMG"},
  {"tool":"gradient_fill","args":{"image_id":"$IMG","color1":"#9a9aa2","color2":"#4a4a52","direction":"vertical"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"ellipse","x":250,"y":150,"width":300,"height":300}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#c8c8d0"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"none"}},
  {"tool":"motion_blur","args":{"image_id":"$IMG","length":40,"angle":0,"kind":"linear"}},
  {"tool":"emboss","args":{"image_id":"$IMG","azimuth":30,"elevation":45,"depth":4,"bumpmap":false}},
  {"tool":"desaturate","args":{"image_id":"$IMG","mode":"value"}},
  {"tool":"brightness_contrast","args":{"image_id":"$IMG","brightness":10,"contrast":35}},
  {"tool":"add_border","args":{"image_id":"$IMG","size":18,"color":"#1a1a1e"}}]},

 {"id":"pixel-mosaic-sunset","task":"Chunky pixel-mosaic treatment over a vivid sunset gradient with a sun disc.","steps":[
  {"tool":"new_image","args":{"width":800,"height":600},"capture":"IMG"},
  {"tool":"gradient_fill","args":{"image_id":"$IMG","color1":"#ffcf5c","color2":"#7a2a6a","direction":"vertical"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"ellipse","x":300,"y":180,"width":200,"height":200}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#ff6a3c"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"none"}},
  {"tool":"hue_saturation","args":{"image_id":"$IMG","hue":0,"saturation":45,"lightness":0}},
  {"tool":"pixelize","args":{"image_id":"$IMG","block":22}},
  {"tool":"brightness_contrast","args":{"image_id":"$IMG","brightness":5,"contrast":20}}]},

 {"id":"radial-flare-burst","task":"Zoom-burst sunburst with a lens flare over a warm radial-feeling gradient.","steps":[
  {"tool":"new_image","args":{"width":800,"height":800},"capture":"IMG"},
  {"tool":"gradient_fill","args":{"image_id":"$IMG","color1":"#1a2038","color2":"#d8863c","direction":"diagonal"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"ellipse","x":330,"y":330,"width":140,"height":140}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#fff2c0"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"none"}},
  {"tool":"motion_blur","args":{"image_id":"$IMG","length":60,"angle":0,"kind":"zoom"}},
  {"tool":"lens_flare","args":{"image_id":"$IMG","x":400,"y":400}},
  {"tool":"brightness_contrast","args":{"image_id":"$IMG","brightness":8,"contrast":25}},
  {"tool":"vignette","args":{"image_id":"$IMG","strength":45,"feather":60}}]},

 {"id":"poster-highcontrast-invert","task":"High-contrast posterized pop-art look with inverted psychedelic hues.","steps":[
  {"tool":"new_image","args":{"width":800,"height":600},"capture":"IMG"},
  {"tool":"gradient_fill","args":{"image_id":"$IMG","color1":"#204080","color2":"#e0e0e0","direction":"horizontal"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"ellipse","x":150,"y":120,"width":260,"height":360}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#c02040"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"rectangle","x":440,"y":160,"width":240,"height":300}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#20a060"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"none"}},
  {"tool":"curves_adjust","args":{"image_id":"$IMG","channel":"value","points":"0,0 64,10 128,128 192,245 255,255"}},
  {"tool":"brightness_contrast","args":{"image_id":"$IMG","brightness":0,"contrast":60}},
  {"tool":"invert","args":{"image_id":"$IMG"}},
  {"tool":"hue_saturation","args":{"image_id":"$IMG","hue":0,"saturation":40,"lightness":0}}]},

 {"id":"faded-filmgrain-portrait","task":"Soft faded film-grain portrait treatment with vignette over a muted gradient.","steps":[
  {"tool":"new_image","args":{"width":700,"height":800},"capture":"IMG"},
  {"tool":"gradient_fill","args":{"image_id":"$IMG","color1":"#b8a890","color2":"#5c6a6e","direction":"vertical"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"ellipse","x":210,"y":220,"width":280,"height":340}},
  {"tool":"fill","args":{"image_id":"$IMG","color":"#d8c4a8"}},
  {"tool":"select","args":{"image_id":"$IMG","shape":"none"}},
  {"tool":"gaussian_blur","args":{"image_id":"$IMG","radius":4}},
  {"tool":"curves_adjust","args":{"image_id":"$IMG","channel":"value","points":"0,30 128,135 255,225"}},
  {"tool":"apply_recipe","args":{"name":"vintage","image_id":"$IMG","params":"{\"desat\":30,\"grain\":28,\"vignette\":50}"}}]}
]
