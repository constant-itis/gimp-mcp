[
  {
    "id": "varsity-collegiate-arch",
    "task": "A collegiate varsity emblem: 'BRUINS' arched over the year 1924 in stacked athletic lettering on a navy field with a cream outline.",
    "steps": [
      {"tool": "new_image", "args": {"width": 1000, "height": 1000}, "capture": "IMG"},
      {"tool": "fill", "args": {"image_id": "$IMG", "color": "#0d1b3e"}},
      {"tool": "arc_text", "args": {"image_id": "$IMG", "text": "BRUINS", "radius": 300, "size": 130, "font": "Serif Bold", "color": "#f4e9c1", "center_angle": 90, "step_deg": 9}},
      {"tool": "outline_text", "args": {"image_id": "$IMG", "text": "1924", "x": 500, "y": 520, "size": 200, "fill_color": "#c9a227", "outline_color": "#f4e9c1", "outline_width": 7, "font": "Serif Bold", "anchor": "center"}},
      {"tool": "arc_text", "args": {"image_id": "$IMG", "text": "ATHLETIC CLUB", "radius": 300, "size": 70, "font": "Sans Bold", "color": "#f4e9c1", "center_angle": 270, "step_deg": 12, "flip": true}}
    ]
  },
  {
