      {"tool": "apply_recipe", "args": {"name": "distressed-text", "image_id": "$IMG", "params": "{\"grit\": 82}"}},
      {"tool": "add_text", "args": {"image_id": "$IMG", "text": "FRAGILE - THIS SIDE UP", "x": 600, "y": 410, "size": 46, "color": "#e8e4d0", "font": "Monospace Bold", "anchor": "center"}}
    ]
  },
