[
  {
    "id": "diecut-circle-badge",
    "task": "Build a two-tone circular badge with arced text, knock the white background to alpha, and export a die-cut transparent sticker.",
    "steps": [
      {
        "tool": "new_image",
        "args": {
          "width": 700,
          "height": 700
        },
        "capture": "IMG"
      },
      {
        "tool": "select",
        "args": {
          "image_id": "$IMG",
          "shape": "ellipse",
          "x": 90,
          "y": 90,
          "width": 520,
          "height": 520
        }
      },
      {
        "tool": "fill",
        "args": {
          "image_id": "$IMG",
          "color": "#1b7a5a"
        }
      },
      {
        "tool": "select",
        "args": {
          "image_id": "$IMG",
          "shape": "ellipse",
          "x": 160,
          "y": 160,
          "width": 380,
          "height": 380
        }
      },
      {
        "tool": "fill",
        "args": {
          "image_id": "$IMG",
          "color": "#f4d35e"
        }
      },
      {
        "tool": "select",
        "args": {
          "image_id": "$IMG",
          "shape": "none"
        }
      },
      {
        "tool": "add_text",
        "args": {
          "image_id": "$IMG",
          "text": "EST 2130",
          "x": 350,
          "y": 350,
          "size": 54,
          "color": "#1b7a5a",
          "font": "Sans Bold",
          "anchor": "center"
        }
      },
      {
        "tool": "arc_text",
        "args": {
          "image_id": "$IMG",
          "text": "RESTORATION GUILD",
          "radius": 210,
          "size": 40,
          "font": "Sans Bold",
          "color": "#ffffff",
          "center_angle": 270,
          "step_deg": 18,
          "flip": false
        }
      },
      {
        "tool": "color_to_alpha",
        "args": {
          "image_id": "$IMG",
          "color": "#ffffff"
        }
      },
      {
        "tool": "trim_to_content",
        "args": {
          "image_id": "$IMG"
        }
      },
      {
        "tool": "export_image",
        "args": {
          "image_id": "$IMG",
          "path": "/tmp/teach_diecut_circle_badge.png"
        }
      }
    ]
  },
  {
    "id": "knockout-gradient-wordmark",
    "task": "Create a bold wordmark over a gradient panel, knock out the white, and export a transparent logo.",
    "steps": [
      {
