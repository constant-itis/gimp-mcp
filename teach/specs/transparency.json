          "y": 120,
          "width": 780,
          "height": 160
        }
      },
      {
        "tool": "gradient_fill",
        "args": {
          "image_id": "$IMG",
          "color1": "#ff5f6d",
          "color2": "#ffc371",
          "direction": "horizontal"
