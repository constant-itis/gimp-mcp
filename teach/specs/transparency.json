          "x": 450,
          "y": 200,
          "size": 120,
          "font": "Sans Bold",
          "anchor": "center",
          "fill_color": "#ffffff"
        }
      },
      {
        "tool": "color_to_alpha",
        "args": {
          "image_id": "$IMG",
          "color": "#ffffff"
        }
      },
      {
        "tool": "trim_to_content",
        "args": {
          "image_id": "$IMG"
        }
      },
      {
        "tool": "export_image",
        "args": {
          "image_id": "$IMG",
          "path": "/tmp/teach_knockout_gradient_wordmark.png"
        }
      }
    ]
  },
  {
    "id": "sticker-outline-star",
    "task": "Draw a colored disc, trim it to alpha, then apply the sticker-outline recipe to give it a die-cut white edge and shadow.",
    "steps": [
      {
        "tool": "new_image",
        "args": {
          "width": 600,
          "height": 600
        },
        "capture": "IMG"
      },
      {
        "tool": "select",
        "args": {
          "image_id": "$IMG",
          "shape": "ellipse",
          "x": 150,
          "y": 150,
          "width": 300,
          "height": 300
        }
      },
      {
        "tool": "fill",
        "args": {
          "image_id": "$IMG",
          "color": "#8e44ad"
        }
      },
      {
        "tool": "select",
        "args": {
          "image_id": "$IMG",
          "shape": "none"
        }
      },
      {
        "tool": "add_text",
        "args": {
          "image_id": "$IMG",
          "text": "GO",
          "x": 300,
          "y": 300,
          "size": 110,
          "color": "#ffffff",
          "font": "Sans Bold",
          "anchor": "center"
        }
      },
      {
        "tool": "color_to_alpha",
        "args": {
          "image_id": "$IMG",
          "color": "#ffffff"
        }
      },
      {
        "tool": "trim_to_content",
        "args": {
          "image_id": "$IMG"
        }
      },
      {
        "tool": "apply_recipe",
        "args": {
          "name": "sticker-outline",
          "image_id": "$IMG",
          "params": "{\"outline\":16,\"outline_color\":\"#ffffff\",\"shadow\":20}"
        }
      },
      {
        "tool": "export_image",
        "args": {
          "image_id": "$IMG",
          "path": "/tmp/teach_sticker_outline_star.png"
        }
      }
    ]
  },
